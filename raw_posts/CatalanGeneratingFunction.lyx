\begin_layout Standard
\begin_inset Formula $\left(1+F\left(x\right)+\ldots+F\left(x\right)^{n}\right)\left(F\left(x\right)-1\right)=F\left(x\right)^{n+1}-1$
\end_inset


\end_layout

\begin_layout Standard
זו זהות שאפשר להוכיח בכל חוג קומוטטיבי.
 עכשיו, אם 
\begin_inset Formula $F_{0}=0$
\end_inset

 אז המקדם החופשי של 
\begin_inset Formula $F\left(x\right)-1$
\end_inset

 שונה מאפס ולכן הוא הפיך, ולכן אפשר לכפול בהופכי ולקבל
\end_layout

\begin_layout Standard
\begin_inset Formula $1+F\left(x\right)+\ldots+F\left(x\right)^{n}=\frac{F\left(x\right)^{n+1}-1}{F\left(x\right)-1}$
\end_inset


