    shifted = [0] * n
\end_layout

\begin_layout Verbatim*

    for i in range(n):
\end_layout

\begin_layout Verbatim*

        shifted[i] = sum(
\end_layout

\begin_layout Verbatim*

            coeffs[k] * math.comb(k, i) * a**(k-i)
\end_layout

\begin_layout Verbatim*

            for k in range(i, n)
\end_layout

\begin_layout Verbatim*

        )
\end_layout

\begin_layout Verbatim*

